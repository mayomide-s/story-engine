# Story Engine managed production template
# Placeholder values only. Do not commit real credentials.

# Application
ENVIRONMENT=production
VIDEO_PROVIDER=runway
STORAGE_PROVIDER=r2
LOCAL_STORAGE_PATH=/app/storage
AUTH_ENABLED=true
APP_ACCESS_PASSWORD=<generate-a-production-access-password>
APP_SESSION_SECRET=<generate-a-production-session-secret>
RUN_MIGRATIONS_ON_STARTUP=false
REQUIRE_SCHEMA_UP_TO_DATE=true

# Frontend
# Verified from frontend/src/api/client.ts: the browser base must include /api.
VITE_API_BASE_URL=https://api.storyengine.soremekun.org/api
FRONTEND_HOST=storyengine.soremekun.org
API_HOST=api.storyengine.soremekun.org

# Database
DATABASE_URL=postgresql+psycopg://<user>:<password>@<private-host>:<port>/storyengine?sslmode=require

# Valkey / Redis-compatible broker
REDIS_URL=rediss://:<password>@<private-host>:<port>/0

# Sessions and CSRF
SESSION_COOKIE_NAME=story_engine_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_MAX_AGE_SECONDS=43200
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=true
CSRF_HEADER_NAME=X-CSRF-Token

# Hosts and CORS
ALLOWED_HOSTS=storyengine.soremekun.org,api.storyengine.soremekun.org
CORS_ALLOWED_ORIGINS=https://storyengine.soremekun.org

# Proxy handling
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_CIDRS=<comma-separated-trusted-proxy-cidrs>
CLIENT_MAX_BODY_SIZE=256m
PROXY_READ_TIMEOUT=900s
PROXY_SEND_TIMEOUT=900s
NGINX_TLS_CERT_PATH=/etc/nginx/tls/fullchain.pem
NGINX_TLS_KEY_PATH=/etc/nginx/tls/privkey.pem
NGINX_TLS_MOUNT_DIR=./deploy/nginx/tls

# Google OAuth
SOCIAL_TOKEN_ENCRYPTION_KEY=<generate-a-fernet-key>
GOOGLE_OAUTH_CLIENT_ID=<google-oauth-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=https://api.storyengine.soremekun.org/api/social-connections/youtube/callback
GOOGLE_OAUTH_FRONTEND_SUCCESS_URL=https://storyengine.soremekun.org/app
GOOGLE_OAUTH_FRONTEND_ERROR_URL=https://storyengine.soremekun.org/app

# YouTube publishing
YOUTUBE_DEFAULT_CATEGORY_ID=27
YOUTUBE_UPLOAD_CHUNK_SIZE_BYTES=8388608
YOUTUBE_TOKEN_REFRESH_LEEWAY_SECONDS=300
YOUTUBE_CLAIM_TIMEOUT_SECONDS=300
YOUTUBE_MAX_RETRY_ATTEMPTS=5
YOUTUBE_POLL_INTERVAL_SECONDS=30
YOUTUBE_MAX_POLL_ATTEMPTS=20

# Cloudflare R2
R2_ACCOUNT_ID=<cloudflare-r2-account-id>
R2_ACCESS_KEY_ID=<cloudflare-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<cloudflare-r2-secret-access-key>
R2_BUCKET_NAME=story-engine-prod-assets
R2_PUBLIC_BASE_URL=https://assets.storyengine.soremekun.org

# Runway / OpenAI
RUNWAY_API_KEY=<runway-api-key>
OPENAI_API_KEY=<openai-api-key-if-needed>
SEMANTIC_CRITIC_ENABLED=false
SEMANTIC_CRITIC_PROVIDER=openai
SEMANTIC_CRITIC_MODEL=gpt-4.1-mini
SEMANTIC_CRITIC_VERSION=v1
SEMANTIC_CRITIC_TIMEOUT_SECONDS=60
NARRATION_ENABLED=false
NARRATION_WRITER_PROVIDER=mock
NARRATION_WRITER_MODEL=gpt-4.1-mini
NARRATION_WRITER_PROMPT_VERSION=v1
NARRATION_SPEECH_PROVIDER=mock
NARRATION_SPEECH_MODEL=gpt-4o-mini-tts
NARRATION_VOICE=alloy
NARRATION_VERSION=v1
NARRATION_CAPTION_VERSION=v1
NARRATION_RENDER_VERSION=v1
NARRATION_TIMEOUT_SECONDS=90
NARRATION_MAX_WORDS=20
NARRATION_MAX_ATEMPO_ADJUSTMENT_PERCENT=10

# Rate limiting
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
SENSITIVE_RATE_LIMIT_ATTEMPTS=10
SENSITIVE_RATE_LIMIT_WINDOW_SECONDS=300
PUBLICATION_RATE_LIMIT_ATTEMPTS=10
PUBLICATION_RATE_LIMIT_WINDOW_SECONDS=300
COMPLIANCE_WRITE_RATE_LIMIT_ATTEMPTS=20
COMPLIANCE_WRITE_RATE_LIMIT_WINDOW_SECONDS=600
