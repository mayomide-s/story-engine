# Core runtime
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/sociopost
REDIS_URL=redis://redis:6379/0
VIDEO_PROVIDER=mock
STORAGE_PROVIDER=local
VITE_API_BASE_URL=http://localhost:8000/api
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Private staging access
AUTH_ENABLED=false
APP_ACCESS_PASSWORD=change-me-for-private-staging
APP_SESSION_SECRET=optional-separate-session-signing-secret

# Paid video generation
RUNWAY_API_KEY=your-runway-api-key

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com
