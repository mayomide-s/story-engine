# Core runtime
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/sociopost
REDIS_URL=redis://redis:6379/0
VIDEO_PROVIDER=mock
STORAGE_PROVIDER=local
VITE_API_BASE_URL=http://localhost:8000/api
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Private staging access
AUTH_ENABLED=false
APP_ACCESS_PASSWORD=change-me-for-private-staging
APP_SESSION_SECRET=optional-separate-session-signing-secret

# Publishing Gateway / Google OAuth
# Leave these blank until you are ready to configure YouTube publishing locally or in staging.
SOCIAL_TOKEN_ENCRYPTION_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_FRONTEND_SUCCESS_URL=
GOOGLE_OAUTH_FRONTEND_ERROR_URL=
YOUTUBE_DEFAULT_CATEGORY_ID=27
YOUTUBE_UPLOAD_CHUNK_SIZE_BYTES=8388608
YOUTUBE_TOKEN_REFRESH_LEEWAY_SECONDS=300
YOUTUBE_CLAIM_TIMEOUT_SECONDS=300
YOUTUBE_MAX_RETRY_ATTEMPTS=5
YOUTUBE_POLL_INTERVAL_SECONDS=30
YOUTUBE_MAX_POLL_ATTEMPTS=20

# Paid video generation
RUNWAY_API_KEY=your-runway-api-key
OPENAI_API_KEY=your-openai-api-key
SEMANTIC_CRITIC_ENABLED=false
SEMANTIC_CRITIC_PROVIDER=openai
SEMANTIC_CRITIC_MODEL=gpt-4.1-mini
SEMANTIC_CRITIC_VERSION=v1
SEMANTIC_CRITIC_TIMEOUT_SECONDS=60

# Narration and captions
NARRATION_ENABLED=false
NARRATION_WRITER_PROVIDER=mock
NARRATION_WRITER_MODEL=gpt-4.1-mini
NARRATION_WRITER_PROMPT_VERSION=v1
NARRATION_SPEECH_PROVIDER=mock
NARRATION_SPEECH_MODEL=gpt-4o-mini-tts
NARRATION_VOICE=alloy
NARRATION_VERSION=v1
NARRATION_CAPTION_VERSION=v1
NARRATION_RENDER_VERSION=v1
NARRATION_TIMEOUT_SECONDS=90
NARRATION_MAX_WORDS=20
NARRATION_MAX_ATEMPO_ADJUSTMENT_PERCENT=10

# Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com
